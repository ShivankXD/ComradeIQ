# Required for real server-side AI missions. Never expose or commit this key.
OPENAI_API_KEY=

# Configurable OpenAI Responses API model. See the official model catalog before changing it.
OPENAI_MODEL=gpt-5.6-terra

# Optional explicit vision-capable model for supported image attachments.
OPENAI_VISION_MODEL=

# Required for deployment-safe mission/event persistence and durable artifact downloads.
# Connect a PRIVATE Vercel Blob store and provide its server-side token.
BLOB_READ_WRITE_TOKEN=

# Alternative Vercel workload identity configuration when supplied by the platform.
VERCEL_OIDC_TOKEN=
BLOB_STORE_ID=

# Optional best-effort realtime enhancement. SSE progress works without this.
ABLY_API_KEY=

# Optional server-side guardrails (defaults shown in README).
COMRADEIQ_MISSION_TIMEOUT_SECONDS=55
COMRADEIQ_MAX_CONCURRENT_MISSIONS=3
COMRADEIQ_MAX_MISSIONS_PER_MINUTE=6
COMRADEIQ_MAX_ATTACHMENTS=3
COMRADEIQ_MAX_ATTACHMENT_BYTES=4194304

# Keep moderation enabled by default. Set only when an approved policy requires it.
COMRADEIQ_DISABLE_MODERATION=false
